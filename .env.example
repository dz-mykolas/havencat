# Copy to `.env` and edit. Real shell env vars override these.
# This file is loaded by `make server` / `make run` / `dart run bin/serve.dart`.
#
# Server vars (PORT, HOST, etc.) are passed as shell env vars via the Makefile.
# Flutter vars (LOG_LEVEL, LLM_PROXY, etc.) are forwarded as --dart-define.

# ── Server (bin/serve.dart) ──────────────────────────────────────────────
PORT=8088
HOST=127.0.0.1
# WEB_ROOT=build/web
# LLM_ALLOWED_HOSTS=api.openai.com,api.anthropic.com

# ── Logging ─────────────────────────────────────────────────────────────
# Dart log level: debug/info/warning/severe (default info)
# Used by both server and Flutter (forwarded via --dart-define).
LOG_LEVEL=debug
# Rust tracing filter: debug/trace/web_retrieval=trace
RUST_LOG=info

# ── Web retrieval providers (server-only) ────────────────────────────────
# Comma-separated. exa:<key> or searxng:<instance-url>
SEARCH_PROVIDERS=exa
# FETCH_PROVIDERS=direct_http,jina_reader:JINA_KEY

# ── Flutter app (forwarded via --dart-define) ───────────────────────────
# LLM proxy base URL for browser requests. Default /proxy = same-origin.
# LLM_PROXY is auto-set by the Makefile for `make run`; only set this if you
# need to override.
# LLM_PROXY=http://localhost:8088/proxy
# APP_NAME=HavenCat
# CODEX_CLIENT_VERSION=0.141.0
