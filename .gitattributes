# Normalize line endings to LF in the repo, regardless of OS.
# This stops the CRLF/LF churn when developers switch between Windows and Unix.
* text=auto eol=lf

# Source files — always LF.
*.dart     text eol=lf
*.yaml     text eol=lf
*.yml      text eol=lf
*.json     text eol=lf
*.md       text eol=lf
*.sh       text eol=lf
*.html     text eol=lf
*.css      text eol=lf
*.js       text eol=lf
*.ts       text eol=lf
*.cc       text eol=lf
*.cpp      text eol=lf
*.h        text eol=lf
*.cmake    text eol=lf
*.swift    text eol=lf
*.kt       text eol=lf
*.gradle   text eol=lf
*.gradle.kts text eol=lf
*.xml      text eol=lf
*.plist    text eol=lf
Makefile   text eol=lf

# Windows-only scripts keep CRLF.
*.bat      text eol=crlf
*.cmd      text eol=crlf
*.ps1      text eol=crlf

# Binary files — never normalize.
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.webp     binary
*.ico      binary
*.icns     binary
*.pdf      binary
*.ttf      binary
*.otf      binary
*.woff     binary
*.woff2    binary
*.zip      binary
*.gz       binary
*.tar      binary
*.so       binary
*.dll      binary
*.dylib    binary
*.exe      binary
*.a        binary
