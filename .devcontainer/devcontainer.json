{
  "name": "havencat",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "remoteUser": "vscode",
  "postCreateCommand": "cd apps && fvm install stable && fvm flutter pub get && fvm flutter doctor -v",
  "customizations": {
    "vscode": {
      "extensions": [
        "Dart-Code.dart-code",
        "Dart-Code.flutter"
      ],
      "settings": {
        "dart.flutterSdkPath": "/opt/flutter",
        "dart.checkForSdkUpdates": false,
        "editor.formatOnSave": true
      }
    }
  }
}